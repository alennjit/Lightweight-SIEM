{
  "manifest_version": 3,
  "name": "Lightweight SIEM Protection",
  "version": "0.1.0",
  "description": "Warns before visiting known-malicious or suspicious links flagged by Lightweight SIEM.",
  "permissions": ["webNavigation", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
